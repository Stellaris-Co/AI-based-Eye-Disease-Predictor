GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OLLAMA_URL=
OLLAMA_MODEL=llama3.2:3b

FORCE_CPU=false

MODELS_DIR=./models

MAX_FILE_SIZE_BYTES=20971520

ENVIRONMENT=development

CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

PORT=8000
HOST=0.0.0.0

LOG_FORMAT=json

PREDICT_RATE_LIMIT=10/minute
CHAT_RATE_LIMIT=30/minute

JWT_SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_DEPLOYMENT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Defaults to a local SQLite file if unset — fine for development, not for
# multi-instance production deployments. Use Postgres in production, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/ophthalmoai
DATABASE_URL=sqlite:///./ophthalmoai.db

MC_DROPOUT_PASSES=8
ENABLE_UNCERTAINTY=true
ENABLE_IQA=true

PERSIST_SCANS=true

MODEL_REGISTRY_JSON=./models/registry.json

SCAN_STORAGE_BUCKET=
SCAN_STORAGE_KMS_KEY_ID=
AWS_REGION=us-east-1
